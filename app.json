{
  "expo": {
    "name": "AquaFerme_Pro",
    "slug": "AquaFerme_Pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logo1.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/LogoKamagri.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Cette application utilise la caméra pour prendre des photos.",
        "NSPhotoLibraryUsageDescription": "Cette application accède à votre galerie pour sélectionner des photos."
      },
      "bundleIdentifier": "com.kamcenter.aquafermepro"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/LogoKamagri.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.kamcenter.aquafermepro"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging"
    ],
    "extra": {
      "eas": {
        "projectId": "2cb5d031-529d-41dd-afe8-431417aec3ac"
      }
    },
    "owner": "kamaso"
  }
}
